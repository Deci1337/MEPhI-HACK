<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ===== PHOTON Design System ===== -->

    <!-- Legacy chat colors -->
    <Color x:Key="Coal">#1C1C1C</Color>
    <Color x:Key="CoalPanel">#181818</Color>
    <Color x:Key="CoalSurface">#222222</Color>
    <Color x:Key="CoalInput">#1A1A1A</Color>
    <Color x:Key="CoalBorder">#2E2E2E</Color>
    <Color x:Key="SeaShell">#FFF5EE</Color>
    <Color x:Key="SeaShellMuted">#7A7570</Color>
    <Color x:Key="AccentBlue">#4A90D9</Color>
    <Color x:Key="DangerRed">#7A1F1F</Color>
    <Color x:Key="SuccessGreen">#1A4A20</Color>

    <!-- Brand -->
    <Color x:Key="AppBackground">#181B1B</Color>
    <Color x:Key="SurfaceCard">#1E2424</Color>
    <Color x:Key="SurfaceCardAlt">#232929</Color>
    <Color x:Key="Accent">#00CDB0</Color>
    <Color x:Key="AccentDim">#1A3D38</Color>
    <Color x:Key="AccentText">#00CDB0</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#FAFAFA</Color>
    <Color x:Key="TextSecondary">#8A9090</Color>
    <Color x:Key="TextMuted">#5C6666</Color>
    <Color x:Key="TextSubtitle">#DFE2E2</Color>

    <!-- Radar rings -->
    <Color x:Key="RadarRing1">#15B9D233</Color>
    <Color x:Key="RadarRing2">#15B9D266</Color>
    <Color x:Key="RadarCore">#0D2926</Color>

    <!-- Status -->
    <Color x:Key="StatusReady">#00CDB0</Color>
    <Color x:Key="StatusBusy">#F97316</Color>
    <Color x:Key="BadgeRed">#EF4444</Color>

    <!-- Connect button -->
    <Color x:Key="ConnectBtnBg">#2D3539</Color>
    <Color x:Key="ConnectBtnText">#FFFFFF</Color>

    <!-- Device card -->
    <Color x:Key="DeviceCardBg">#1A1E1E</Color>

    <!-- Tab bar -->
    <Color x:Key="TabBarBg">#111414</Color>
    <Color x:Key="TabActive">#00CDB0</Color>
    <Color x:Key="TabInactive">#4A5555</Color>

    <!-- Legacy compatibility -->
    <Color x:Key="Primary">#00CDB0</Color>
    <Color x:Key="PrimaryDark">#00CDB0</Color>
    <Color x:Key="PrimaryDarkText">#181B1B</Color>
    <Color x:Key="Secondary">#1E2424</Color>
    <Color x:Key="SecondaryDarkText">#8A9090</Color>
    <Color x:Key="Tertiary">#232929</Color>
    <Color x:Key="White">#FAFAFA</Color>
    <Color x:Key="Black">#181B1B</Color>
    <Color x:Key="OffBlack">#111414</Color>
    <Color x:Key="Magenta">#00CDB0</Color>
    <Color x:Key="MidnightBlue">#181B1B</Color>

    <Color x:Key="Gray100">#2A3030</Color>
    <Color x:Key="Gray200">#3A4444</Color>
    <Color x:Key="Gray300">#4A5555</Color>
    <Color x:Key="Gray400">#5C6666</Color>
    <Color x:Key="Gray500">#6E7A7A</Color>
    <Color x:Key="Gray600">#8A9090</Color>
    <Color x:Key="Gray900">#CCDADA</Color>
    <Color x:Key="Gray950">#FAFAFA</Color>

    <SolidColorBrush x:Key="PrimaryBrush"     Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush"   Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush"    Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush"       Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush"       Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush"     Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush"     Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush"     Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush"     Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush"     Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush"     Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush"     Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush"     Color="{StaticResource Gray950}"/>
</ResourceDictionary>