<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ===== PHOTON B&W Design System ===== -->

    <!-- Background layers -->
    <Color x:Key="Coal">#000000</Color>
    <Color x:Key="CoalPanel">#0A0A0A</Color>
    <Color x:Key="CoalSurface">#141414</Color>
    <Color x:Key="CoalInput">#0F0F0F</Color>
    <Color x:Key="CoalBorder">#2A2A2A</Color>
    <Color x:Key="CoalElevated">#1A1A1A</Color>

    <!-- Text -->
    <Color x:Key="SeaShell">#FFFFFF</Color>
    <Color x:Key="SeaShellMuted">#888888</Color>
    <Color x:Key="SeaShellDim">#555555</Color>

    <!-- Accents (All grayscale for B&W theme) -->
    <Color x:Key="AccentBlue">#FFFFFF</Color>
    <Color x:Key="AccentBlueDark">#CCCCCC</Color>
    <Color x:Key="AccentGreen">#FFFFFF</Color>
    <Color x:Key="AccentGreenDark">#AAAAAA</Color>
    <Color x:Key="AccentAmber">#DDDDDD</Color>
    <Color x:Key="DangerRed">#FFFFFF</Color>
    <Color x:Key="DangerRedDark">#333333</Color>
    <Color x:Key="SuccessGreen">#FFFFFF</Color>
    <Color x:Key="SuccessGreenDark">#444444</Color>

    <!-- Legacy compatibility -->
    <Color x:Key="Primary">#FFFFFF</Color>
    <Color x:Key="PrimaryDark">#CCCCCC</Color>
    <Color x:Key="PrimaryDarkText">#000000</Color>
    <Color x:Key="Secondary">#141414</Color>
    <Color x:Key="SecondaryDarkText">#888888</Color>
    <Color x:Key="Tertiary">#1A1A1A</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="OffBlack">#0A0A0A</Color>
    <Color x:Key="Magenta">#FFFFFF</Color>
    <Color x:Key="MidnightBlue">#000000</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <SolidColorBrush x:Key="PrimaryBrush"     Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush"   Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush"    Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush"       Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush"       Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush"     Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush"     Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush"     Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush"     Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush"     Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush"     Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush"     Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush"     Color="{StaticResource Gray950}"/>

</ResourceDictionary>
