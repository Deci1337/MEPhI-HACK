<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MassangerMaximka"
             xmlns:conv="clr-namespace:MassangerMaximka.Converters"
             x:Class="MassangerMaximka.MainPage"
             Title="PHOTON"
             BackgroundColor="{StaticResource Coal}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:ByteArrayToImageSourceConverter x:Key="ByteArrayToImageSourceConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid x:Name="RootLayout" ColumnSpacing="0" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{OnIdiom Phone=140, Default=220}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ====== LEFT: Peers sidebar ====== -->
        <Grid x:Name="SidebarPanel" Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" BackgroundColor="{StaticResource CoalPanel}"
              RowDefinitions="Auto,Auto,*,Auto" RowSpacing="0">

            <!-- Sidebar header -->
            <StackLayout Grid.Row="0" Padding="10,14,10,10" Spacing="2">
                <Label Text="PHOTON" FontSize="{OnIdiom Phone=13, Default=16}"
                       FontAttributes="Bold" TextColor="{StaticResource SeaShell}" />
                <Label x:Name="StatusLabel" Text="Starting..." FontSize="9"
                       TextColor="{StaticResource SeaShellMuted}" />
                <Label x:Name="PortHintLabel" Text="" FontSize="8"
                       TextColor="{StaticResource SeaShellMuted}" />
            </StackLayout>
            <BoxView Grid.Row="0" HeightRequest="1" Color="{StaticResource CoalBorder}" VerticalOptions="End" />

            <!-- Peers count -->
            <Label Grid.Row="1" x:Name="PeersLabel" Text="Peers: 0"
                   FontSize="9" TextColor="{StaticResource SeaShellMuted}"
                   Padding="10,6,10,2" />

            <!-- Peers list -->
            <CollectionView Grid.Row="2" x:Name="PeersList" SelectionMode="Single"
                            SelectionChanged="OnPeerSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Grid Padding="{OnIdiom Phone='8,10', Default='10,10'}"
                              BackgroundColor="Transparent"
                              MinimumHeightRequest="{OnIdiom Phone=44, Default=36}">
                            <Label Text="{Binding}" FontSize="{OnIdiom Phone=11, Default=12}"
                                   TextColor="{StaticResource SeaShell}"
                                   LineBreakMode="TailTruncation"
                                   VerticalOptions="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Connect section -->
            <StackLayout Grid.Row="3" Padding="6,6,6,10" Spacing="5">
                <BoxView HeightRequest="1" Color="{StaticResource CoalBorder}" />
                <Entry x:Name="ManualIpEntry" Placeholder="IP:port"
                       FontSize="{OnIdiom Phone=10, Default=11}"
                       BackgroundColor="{StaticResource CoalInput}"
                       TextColor="{StaticResource SeaShell}"
                       PlaceholderColor="{StaticResource SeaShellMuted}" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="4">
                    <Button Grid.Column="0" Text="Connect" Clicked="OnConnectClicked"
                            BackgroundColor="{StaticResource CoalSurface}"
                            TextColor="{StaticResource SeaShell}"
                            FontSize="{OnIdiom Phone=9, Default=10}" Padding="0,6" CornerRadius="3" />
                    <Button Grid.Column="1" Text="Forget" Clicked="OnForgetSavedPeersClicked"
                            BackgroundColor="{StaticResource DangerRed}"
                            TextColor="{StaticResource SeaShell}"
                            FontSize="{OnIdiom Phone=9, Default=10}" Padding="0,6" CornerRadius="3" />
                </Grid>
                <Button Text="+ Channel" Clicked="OnCreateChannelClicked"
                        BackgroundColor="#1A3A1A"
                        TextColor="#88CC88"
                        FontSize="{OnIdiom Phone=9, Default=10}" Padding="0,6" CornerRadius="3" />
            </StackLayout>
        </Grid>

        <!-- Vertical divider -->
        <BoxView x:Name="SidebarDivider" Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" WidthRequest="1" Color="{StaticResource CoalBorder}" HorizontalOptions="End" />

        <!-- ====== RIGHT: Chat panel ====== -->
        <Grid x:Name="ChatPanel" Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" BackgroundColor="{StaticResource Coal}"
              RowDefinitions="Auto,Auto,Auto,3*,Auto,Auto,2*" RowSpacing="0">

            <!-- Chat header: selected peer + call controls -->
            <Grid Grid.Row="0" Padding="12,9,8,9"
                  ColumnDefinitions="*,Auto,Auto,Auto,Auto"
                  ColumnSpacing="6"
                  BackgroundColor="{StaticResource CoalPanel}">
                <StackLayout Grid.Column="0" Spacing="1" VerticalOptions="Center">
                    <Label x:Name="SelectedPeerLabel" Text="Select a peer"
                           FontSize="{OnIdiom Phone=12, Default=14}" FontAttributes="Bold"
                           TextColor="{StaticResource SeaShell}" />
                    <Label x:Name="VoiceStatusLabel" Text="Voice: idle"
                           FontSize="9" TextColor="{StaticResource SeaShellMuted}" />
                </StackLayout>
                <Button Grid.Column="1" x:Name="RecordBtn" Text="REC"
                        Clicked="OnRecordVoiceClicked"
                        BackgroundColor="{StaticResource DangerRed}"
                        TextColor="{StaticResource SeaShell}"
                        FontSize="10" Padding="8,4" CornerRadius="3" />
                <Button Grid.Column="2" x:Name="StopSendBtn" Text="STOP"
                        Clicked="OnStopSendVoiceClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShell}"
                        FontSize="10" Padding="8,4" CornerRadius="3" />
                <Button Grid.Column="3" x:Name="PttBtn" Text="Talk"
                        IsVisible="False"
                        Pressed="OnPttPressed" Released="OnPttReleased"
                        BackgroundColor="{StaticResource AccentBlue}"
                        TextColor="{StaticResource SeaShell}"
                        FontSize="10" Padding="14,4" CornerRadius="3" />
                <Button Grid.Column="4" x:Name="CallBtn" Text="Call"
                        Clicked="OnCallButtonClicked"
                        BackgroundColor="{StaticResource SuccessGreen}"
                        TextColor="{StaticResource SeaShell}"
                        FontSize="10" Padding="10,4" CornerRadius="3" />
            </Grid>
            <BoxView Grid.Row="0" HeightRequest="1" Color="{StaticResource CoalBorder}" VerticalOptions="End" />

            <!-- Channel status bar (visible when in a channel) -->
            <Grid Grid.Row="1" x:Name="ChannelBar" IsVisible="False"
                  BackgroundColor="#0D1F0D" Padding="10,5,10,5"
                  ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                <StackLayout Grid.Column="0" Spacing="1" VerticalOptions="Center">
                    <Label x:Name="ChannelInfoLabel"
                           Text="Channel: — | Members: 0"
                           TextColor="#88CC88" FontSize="11" />
                    <Label x:Name="ChannelPttLabel" IsVisible="False"
                           TextColor="#FF9800" FontSize="11" FontAttributes="Bold" />
                </StackLayout>
                <Button Grid.Column="1" Text="Invite+" Clicked="OnInviteToChannelClicked"
                        BackgroundColor="#1A3A1A"
                        TextColor="#88CC88"
                        FontSize="9" Padding="8,3" CornerRadius="3" />
                <Button Grid.Column="2" x:Name="LeaveChannelBtn" Text="Leave"
                        Clicked="OnLeaveChannelClicked"
                        BackgroundColor="{StaticResource DangerRed}"
                        TextColor="{StaticResource SeaShell}"
                        FontSize="9" Padding="8,3" CornerRadius="3" />
            </Grid>

            <!-- Incoming call banner -->
            <Frame Grid.Row="2" x:Name="IncomingCallBanner" IsVisible="False"
                   BackgroundColor="#182A1A" BorderColor="{StaticResource SuccessGreen}"
                   Padding="10,6" CornerRadius="0" Margin="0">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <Label Grid.Column="0" x:Name="IncomingCallLabel" Text="Incoming call..."
                           TextColor="{StaticResource SeaShell}" FontSize="12"
                           FontAttributes="Bold" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="Accept" Clicked="OnAcceptCallClicked"
                            BackgroundColor="{StaticResource SuccessGreen}"
                            TextColor="{StaticResource SeaShell}" FontSize="10" Padding="12,4" CornerRadius="3" />
                    <Button Grid.Column="2" Text="Decline" Clicked="OnDeclineCallClicked"
                            BackgroundColor="{StaticResource DangerRed}"
                            TextColor="{StaticResource SeaShell}" FontSize="10" Padding="12,4" CornerRadius="3" />
                </Grid>
            </Frame>

            <!-- Chat messages -->
            <CollectionView Grid.Row="3" x:Name="ChatList" Margin="10,6,10,6">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:ChatItem">
                        <Grid Padding="2,3">
                            <!-- Text message -->
                            <Grid IsVisible="{Binding IsText}" ColumnDefinitions="*,Auto" ColumnSpacing="4">
                                <Label Grid.Column="0" Text="{Binding Text}"
                                       LineBreakMode="WordWrap"
                                       FontSize="{OnIdiom Phone=12, Default=13}"
                                       TextColor="{StaticResource SeaShell}" />
                                <Label Grid.Column="1" Text="{Binding Status}"
                                       IsVisible="{Binding HasStatus}"
                                       FontSize="9" TextColor="{StaticResource SeaShellMuted}"
                                       VerticalOptions="End" />
                            </Grid>
                            <!-- Voice message -->
                            <Grid IsVisible="{Binding IsVoice}"
                                  ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Button Grid.Column="0" Text="Play"
                                        BackgroundColor="{StaticResource AccentBlue}"
                                        TextColor="{StaticResource SeaShell}"
                                        FontSize="10" Padding="10,4" CornerRadius="3"
                                        CommandParameter="{Binding VoicePath}"
                                        Clicked="OnVoiceItemPlayClicked" />
                                <Label Grid.Column="1" Text="{Binding Text}"
                                       FontSize="11" TextColor="{StaticResource SeaShellMuted}"
                                       VerticalOptions="Center" LineBreakMode="TailTruncation" />
                            </Grid>
                            <!-- Image message -->
                            <Grid IsVisible="{Binding IsImage}" RowDefinitions="Auto,Auto" RowSpacing="4">
                                <Label Grid.Row="0" Text="{Binding Text}"
                                       FontSize="11" TextColor="{StaticResource SeaShellMuted}"
                                       LineBreakMode="TailTruncation" />
                                <Image Grid.Row="1"
                                       Source="{Binding ImageBytes, Converter={StaticResource ByteArrayToImageSourceConverter}}"
                                       HeightRequest="200"
                                       WidthRequest="200"
                                       Aspect="AspectFill" />
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Message input bar -->
            <Grid x:Name="MessageBarWide" Grid.Row="4" Padding="8,6" ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                  ColumnSpacing="6" BackgroundColor="{StaticResource CoalPanel}">
                <BoxView Grid.ColumnSpan="5" HeightRequest="1" Color="{StaticResource CoalBorder}" VerticalOptions="Start" />
                <Button Grid.Column="0" Text="File" Clicked="OnSendTestFileClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShellMuted}"
                        FontSize="10" Padding="10,6" CornerRadius="3" />
                <Button Grid.Column="1" Text="Photo" Clicked="OnSendPhotoClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShellMuted}"
                        FontSize="10" Padding="10,6" CornerRadius="3" />
                <Entry Grid.Column="2" x:Name="MessageEntry" Placeholder="Message..."
                       BackgroundColor="{StaticResource CoalInput}"
                       TextColor="{StaticResource SeaShell}"
                       PlaceholderColor="{StaticResource SeaShellMuted}"
                       FontSize="{OnIdiom Phone=12, Default=13}" />
                <Button Grid.Column="3" Text="X" Clicked="OnClearChatClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShellMuted}"
                        FontSize="10" Padding="8,6" CornerRadius="3" />
                <Button Grid.Column="4" Text="Send" Clicked="OnSendClicked"
                        BackgroundColor="{StaticResource AccentBlue}"
                        TextColor="{StaticResource SeaShell}"
                        FontSize="{OnIdiom Phone=11, Default=12}"
                        Padding="14,6" CornerRadius="3" />
            </Grid>

            <VerticalStackLayout x:Name="MessageBarNarrow" Grid.Row="4" IsVisible="False"
                                 Padding="8,6" Spacing="6" BackgroundColor="{StaticResource CoalPanel}">
                <BoxView HeightRequest="1" Color="{StaticResource CoalBorder}" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <Entry Grid.Column="0" x:Name="MessageEntryNarrow" Placeholder="Message..."
                           BackgroundColor="{StaticResource CoalInput}"
                           TextColor="{StaticResource SeaShell}"
                           PlaceholderColor="{StaticResource SeaShellMuted}"
                           FontSize="14"
                           Completed="OnSendClicked" />
                    <Button Grid.Column="1" Text="Send" Clicked="OnSendClicked"
                            BackgroundColor="{StaticResource AccentBlue}"
                            TextColor="{StaticResource SeaShell}"
                            FontSize="12"
                            Padding="14,10" CornerRadius="3" />
                </Grid>
                <HorizontalStackLayout Spacing="6">
                    <Button Text="File" Clicked="OnSendTestFileClicked"
                            HorizontalOptions="Start"
                            BackgroundColor="{StaticResource CoalSurface}"
                            TextColor="{StaticResource SeaShellMuted}"
                            FontSize="12" Padding="12,8" CornerRadius="3" />
                    <Button Text="Photo" Clicked="OnSendPhotoClicked"
                            HorizontalOptions="Start"
                            BackgroundColor="{StaticResource CoalSurface}"
                            TextColor="{StaticResource SeaShellMuted}"
                            FontSize="12" Padding="12,8" CornerRadius="3" />
                    <Button Text="Clear" Clicked="OnClearChatClicked"
                            HorizontalOptions="Start"
                            BackgroundColor="{StaticResource CoalSurface}"
                            TextColor="{StaticResource SeaShellMuted}"
                            FontSize="12" Padding="12,8" CornerRadius="3" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- File transfer status row -->
            <Grid x:Name="FileStatusBar" Grid.Row="5" Padding="10,4,8,4"
                  ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="4"
                  BackgroundColor="{StaticResource CoalPanel}">
                <Label Grid.Column="0" x:Name="FileTransferLabel" Text="File: idle"
                       FontSize="9" TextColor="{StaticResource SeaShellMuted}" VerticalOptions="Center" />
                <Button Grid.Column="1" Text="Resume" Clicked="OnResumeFileClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShellMuted}"
                        FontSize="9" Padding="6,2" CornerRadius="3" />
                <Label Grid.Column="2" x:Name="LogCountLabel" Text=""
                       FontSize="9" TextColor="{StaticResource SeaShellMuted}" VerticalOptions="Center" />
                <Button Grid.Column="3" Text="Copy" Clicked="OnCopyLogsClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShellMuted}"
                        FontSize="9" Padding="6,2" CornerRadius="3" />
                <Button Grid.Column="4" x:Name="ClearLogsBtn" Text="Clear" Clicked="OnClearLogsClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShellMuted}"
                        FontSize="9" Padding="6,2" CornerRadius="3" />
            </Grid>

            <!-- Technical logs + Metrics bar -->
            <Grid x:Name="DiagnosticsPanel" Grid.Row="6" RowDefinitions="Auto,Auto,*" BackgroundColor="{StaticResource CoalPanel}">
                <BoxView Grid.Row="0" HeightRequest="1" Color="{StaticResource CoalBorder}" />
                <!-- Metrics bar -->
                <Grid Grid.Row="1" Padding="10,5,10,5" ColumnDefinitions="*,*,*,*" ColumnSpacing="6"
                      BackgroundColor="{StaticResource CoalPanel}">
                    <StackLayout Grid.Column="0" Spacing="1">
                        <Label Text="RTT" FontSize="8" TextColor="{StaticResource SeaShellMuted}" />
                        <Label x:Name="MetricRttLabel" Text="--" FontSize="11"
                               FontAttributes="Bold" TextColor="{StaticResource SeaShell}" />
                    </StackLayout>
                    <StackLayout Grid.Column="1" Spacing="1">
                        <Label Text="LOSS" FontSize="8" TextColor="{StaticResource SeaShellMuted}" />
                        <Label x:Name="MetricLossLabel" Text="--" FontSize="11"
                               FontAttributes="Bold" TextColor="{StaticResource SeaShell}" />
                    </StackLayout>
                    <StackLayout Grid.Column="2" Spacing="1">
                        <Label Text="QUALITY" FontSize="8" TextColor="{StaticResource SeaShellMuted}" />
                        <Label x:Name="MetricQualityLabel" Text="--" FontSize="11"
                               FontAttributes="Bold" TextColor="{StaticResource SeaShell}" />
                    </StackLayout>
                    <StackLayout Grid.Column="3" Spacing="1">
                        <Label Text="RETRIES" FontSize="8" TextColor="{StaticResource SeaShellMuted}" />
                        <Label x:Name="MetricRetriesLabel" Text="--" FontSize="11"
                               FontAttributes="Bold" TextColor="{StaticResource SeaShell}" />
                    </StackLayout>
                </Grid>
                <ScrollView Grid.Row="2" x:Name="TechLogScrollView" Padding="10,6">
                    <VerticalStackLayout x:Name="TechLogStack" Spacing="1" />
                </ScrollView>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
