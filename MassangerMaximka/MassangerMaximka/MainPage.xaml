<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MassangerMaximka.MainPage"
             Title="Hex P2P Test">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label x:Name="StatusLabel" Text="Starting..." FontAttributes="Bold" />
            <Label x:Name="PeersLabel" Text="Peers: 0" />
            <CollectionView x:Name="PeersList" HeightRequest="120" SelectionMode="Single"
                            SelectionChanged="OnPeerSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Label Text="{Binding}" Padding="5" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Manual connect (IP:port):" />
            <Grid ColumnDefinitions="*,Auto">
                <Entry x:Name="ManualIpEntry" Placeholder="192.168.1.10:45680" Grid.Column="0" />
                <Button x:Name="ConnectBtn" Text="Connect" Grid.Column="1" Clicked="OnConnectClicked" />
            </Grid>

            <Label Text="Selected peer:" />
            <Label x:Name="SelectedPeerLabel" Text="(none)" TextColor="Gray" />

            <Label Text="Message:" />
            <Grid ColumnDefinitions="*,Auto">
                <Entry x:Name="MessageEntry" Placeholder="Type message..." Grid.Column="0" />
                <Button x:Name="SendBtn" Text="Send" Grid.Column="1" Clicked="OnSendClicked" />
            </Grid>

            <Label Text="Chat log:" FontAttributes="Bold" />
            <Frame BorderColor="LightGray" Padding="10" HeightRequest="200">
                <ScrollView>
                    <Label x:Name="ChatLogLabel" Text="" LineBreakMode="WordWrap" />
                </ScrollView>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
