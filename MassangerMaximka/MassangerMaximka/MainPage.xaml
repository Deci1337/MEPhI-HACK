<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MassangerMaximka"
             xmlns:conv="clr-namespace:MassangerMaximka.Converters"
             x:Class="MassangerMaximka.MainPage"
             Title="PHOTON"
             BackgroundColor="{StaticResource Coal}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:ByteArrayToImageSourceConverter x:Key="ByteArrayToImageSourceConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid x:Name="RootLayout" ColumnSpacing="0" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{OnIdiom Phone=0, Default=260}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ====== LEFT: Peers sidebar ====== -->
        <Grid x:Name="SidebarPanel" Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
              BackgroundColor="{StaticResource CoalPanel}"
              RowDefinitions="Auto,Auto,*,Auto" RowSpacing="0">

            <!-- App header -->
            <Grid Grid.Row="0" Padding="16,18,16,14" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <!-- Logo circle -->
                <Border Grid.Column="0"
                        BackgroundColor="{StaticResource AccentBlue}"
                        StrokeThickness="0"
                        HeightRequest="34" WidthRequest="34"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Label Text="⚡" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <StackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                    <Label Text="PHOTON" FontSize="15" FontAttributes="Bold"
                           TextColor="{StaticResource SeaShell}" />
                    <Label x:Name="StatusLabel" Text="Starting..." FontSize="10"
                           TextColor="{StaticResource SeaShellMuted}" />
                </StackLayout>
            </Grid>
            <BoxView Grid.Row="0" HeightRequest="1" Color="{StaticResource CoalBorder}" VerticalOptions="End" />

            <!-- Peers section header -->
            <Grid Grid.Row="1" Padding="16,10,16,6" ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" x:Name="PeersLabel" Text="DEVICES"
                       FontSize="10" FontAttributes="Bold" TextColor="{StaticResource SeaShellMuted}"
                       VerticalOptions="Center" />
                <Label Grid.Column="1" x:Name="PortHintLabel" Text=""
                       FontSize="9" TextColor="{StaticResource SeaShellMuted}" VerticalOptions="Center" />
            </Grid>

            <!-- Peers list -->
            <CollectionView Grid.Row="2" x:Name="PeersList" SelectionMode="Single"
                            SelectionChanged="OnPeerSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Grid Padding="10,4,10,4" MinimumHeightRequest="{OnIdiom Phone=52, Default=46}">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer NumberOfTapsRequired="2" Tapped="OnPeerDoubleTapped" />
                            </Grid.GestureRecognizers>
                            <Border BackgroundColor="{StaticResource CoalSurface}"
                                    StrokeThickness="0" Padding="10,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <!-- Avatar circle -->
                                    <Border Grid.Column="0" WidthRequest="32" HeightRequest="32"
                                            StrokeThickness="0" VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="16" />
                                        </Border.StrokeShape>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#3A4A7A" Offset="0" />
                                                <GradientStop Color="#5B6EAF" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Label FontSize="13" FontAttributes="Bold"
                                               TextColor="White"
                                               HorizontalOptions="Center" VerticalOptions="Center">
                                            <Label.Text>
                                                <Binding Path="." StringFormat="{}{0}" />
                                            </Label.Text>
                                        </Label>
                                    </Border>
                                    <!-- Name + status -->
                                    <Label Grid.Column="1" Text="{Binding}"
                                           FontSize="{OnIdiom Phone=12, Default=12}"
                                           TextColor="{StaticResource SeaShell}"
                                           LineBreakMode="TailTruncation"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Connect + actions section -->
            <StackLayout Grid.Row="3" Padding="10,8,10,14" Spacing="6">
                <BoxView HeightRequest="1" Color="{StaticResource CoalBorder}" />
                <Border BackgroundColor="{StaticResource CoalSurface}"
                        StrokeThickness="1" Stroke="{StaticResource CoalBorder}"
                        Padding="4,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Entry x:Name="ManualIpEntry" Placeholder="192.168.1.x:45680"
                           FontSize="{OnIdiom Phone=11, Default=12}"
                           BackgroundColor="Transparent"
                           TextColor="{StaticResource SeaShell}"
                           PlaceholderColor="{StaticResource SeaShellMuted}" />
                </Border>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                    <Button Grid.Column="0" Text="⚡ Connect" Clicked="OnConnectClicked"
                            BackgroundColor="{StaticResource AccentBlue}"
                            TextColor="White"
                            FontSize="11" Padding="0,8" CornerRadius="8" />
                    <Button Grid.Column="1" Text="🗑 Forget" Clicked="OnForgetSavedPeersClicked"
                            BackgroundColor="{StaticResource CoalSurface}"
                            TextColor="{StaticResource DangerRed}"
                            FontSize="11" Padding="0,8" CornerRadius="8" />
                </Grid>
                <Button Text="# Create Channel" Clicked="OnCreateChannelClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource AccentGreen}"
                        FontSize="11" Padding="0,8" CornerRadius="8" />
            </StackLayout>
        </Grid>

        <!-- Vertical divider (desktop only) -->
        <BoxView x:Name="SidebarDivider" Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                 WidthRequest="1" Color="{StaticResource CoalBorder}" HorizontalOptions="End" />

        <!-- ====== RIGHT: Chat panel ====== -->
        <Grid x:Name="ChatPanel" Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
              BackgroundColor="{StaticResource Coal}"
              RowDefinitions="Auto,Auto,Auto,*,Auto,Auto,200" RowSpacing="0">

            <!-- Chat header -->
            <Grid Grid.Row="0" Padding="14,10,10,10"
                  ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto"
                  ColumnSpacing="8"
                  BackgroundColor="{StaticResource CoalPanel}">
                <!-- Mobile back button -->
                <Button Grid.Column="0" x:Name="BackToPeersBtn" Text="‹"
                        Clicked="OnBackToPeersClicked"
                        IsVisible="False"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShell}"
                        FontSize="20" Padding="10,6" CornerRadius="8"
                        HeightRequest="36" />
                <!-- Peer info -->
                <StackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                    <Label x:Name="SelectedPeerLabel" Text="Select a device"
                           FontSize="{OnIdiom Phone=13, Default=15}" FontAttributes="Bold"
                           TextColor="{StaticResource SeaShell}" />
                    <Label x:Name="VoiceStatusLabel" Text="Voice: idle"
                           FontSize="10" TextColor="{StaticResource SeaShellMuted}" />
                </StackLayout>
                <!-- Voice record button -->
                <Button Grid.Column="2" x:Name="RecordBtn" Text="🎙"
                        Clicked="OnRecordVoiceClicked"
                        BackgroundColor="{StaticResource DangerRed}"
                        TextColor="White"
                        FontSize="16" Padding="10,6" CornerRadius="8"
                        HeightRequest="36" WidthRequest="44" />
                <!-- Stop button -->
                <Button Grid.Column="3" x:Name="StopSendBtn" Text="⏹"
                        Clicked="OnStopSendVoiceClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShell}"
                        FontSize="16" Padding="10,6" CornerRadius="8"
                        HeightRequest="36" WidthRequest="44" />
                <!-- PTT button -->
                <Button Grid.Column="4" x:Name="PttBtn" Text="🎤 Talk"
                        IsVisible="False"
                        Pressed="OnPttPressed" Released="OnPttReleased"
                        BackgroundColor="{StaticResource AccentBlue}"
                        TextColor="White"
                        FontSize="12" Padding="14,6" CornerRadius="8"
                        HeightRequest="36" />
                <!-- Call button -->
                <Button Grid.Column="5" x:Name="CallBtn" Text="📞"
                        Clicked="OnCallButtonClicked"
                        BackgroundColor="{StaticResource SuccessGreen}"
                        TextColor="White"
                        FontSize="16" Padding="10,6" CornerRadius="8"
                        HeightRequest="36" WidthRequest="44" />
            </Grid>
            <BoxView Grid.Row="0" HeightRequest="1" Color="{StaticResource CoalBorder}" VerticalOptions="End" />

            <!-- Channel bar -->
            <Grid Grid.Row="1" x:Name="ChannelBar" IsVisible="False"
                  BackgroundColor="#111B1A" Padding="14,8,10,8"
                  ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                <Label Grid.Column="0" Text="#" FontSize="16" TextColor="{StaticResource AccentGreen}"
                       VerticalOptions="Center" />
                <StackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                    <Label x:Name="ChannelInfoLabel" Text="Channel"
                           TextColor="{StaticResource AccentGreen}" FontSize="12" FontAttributes="Bold" />
                    <Label x:Name="ChannelPttLabel" IsVisible="False"
                           TextColor="{StaticResource AccentAmber}" FontSize="11" FontAttributes="Bold" />
                </StackLayout>
                <Button Grid.Column="2" Text="+ Invite" Clicked="OnInviteToChannelClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource AccentGreen}"
                        FontSize="10" Padding="10,4" CornerRadius="6" />
                <Button Grid.Column="3" x:Name="LeaveChannelBtn" Text="Leave"
                        Clicked="OnLeaveChannelClicked"
                        BackgroundColor="{StaticResource DangerRedDark}"
                        TextColor="{StaticResource DangerRed}"
                        FontSize="10" Padding="10,4" CornerRadius="6" />
            </Grid>

            <!-- Incoming call banner -->
            <Border Grid.Row="2" x:Name="IncomingCallBanner" IsVisible="False"
                    BackgroundColor="#0D1F16" StrokeThickness="0" Margin="0">
                <Border.StrokeShape>
                    <Rectangle />
                </Border.StrokeShape>
                <Grid Padding="14,12,12,12" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                    <!-- Pulsing phone icon -->
                    <Border Grid.Column="0"
                            BackgroundColor="{StaticResource AccentGreen}"
                            StrokeThickness="0" WidthRequest="40" HeightRequest="40"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Label Text="📞" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="Incoming call" FontSize="11"
                               TextColor="{StaticResource AccentGreen}" />
                        <Label x:Name="IncomingCallLabel" Text="Unknown"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource SeaShell}" />
                    </StackLayout>
                    <Button Grid.Column="2" Text="✓ Accept" Clicked="OnAcceptCallClicked"
                            BackgroundColor="{StaticResource SuccessGreen}"
                            TextColor="White" FontSize="12"
                            Padding="14,8" CornerRadius="8" />
                    <Button Grid.Column="3" Text="✕ Decline" Clicked="OnDeclineCallClicked"
                            BackgroundColor="{StaticResource DangerRed}"
                            TextColor="White" FontSize="12"
                            Padding="14,8" CornerRadius="8" />
                </Grid>
            </Border>

            <!-- Chat messages -->
            <CollectionView Grid.Row="3" x:Name="ChatList" Margin="12,8,12,8">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:ChatItem">
                        <!-- Text bubble -->
                        <Grid Padding="2,3">
                            <Grid IsVisible="{Binding IsText}">
                                <Border BackgroundColor="{Binding BubbleColor}"
                                        StrokeThickness="0"
                                        Padding="12,8"
                                        MaximumWidthRequest="480"
                                        HorizontalOptions="{Binding BubbleAlign}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14" />
                                    </Border.StrokeShape>
                                    <StackLayout Spacing="4">
                                        <Label Text="{Binding Text}"
                                               LineBreakMode="WordWrap"
                                               FontSize="{OnIdiom Phone=13, Default=13}"
                                               TextColor="{StaticResource SeaShell}" />
                                        <Label Text="{Binding Status}"
                                               IsVisible="{Binding HasStatus}"
                                               FontSize="9" TextColor="{StaticResource SeaShellMuted}"
                                               HorizontalOptions="End" />
                                    </StackLayout>
                                </Border>
                            </Grid>
                            <!-- Voice message -->
                            <Grid IsVisible="{Binding IsVoice}">
                                <Border BackgroundColor="{StaticResource CoalSurface}"
                                        StrokeThickness="0" Padding="10,8"
                                        HorizontalOptions="{Binding BubbleAlign}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <Button Grid.Column="0" Text="▶"
                                                BackgroundColor="{StaticResource AccentBlue}"
                                                TextColor="White"
                                                FontSize="14" Padding="10,6" CornerRadius="6"
                                                CommandParameter="{Binding VoicePath}"
                                                Clicked="OnVoiceItemPlayClicked" />
                                        <Label Grid.Column="1" Text="{Binding Text}"
                                               FontSize="12" TextColor="{StaticResource SeaShellMuted}"
                                               VerticalOptions="Center" LineBreakMode="TailTruncation" />
                                    </Grid>
                                </Border>
                            </Grid>
                            <!-- Image message -->
                            <Grid IsVisible="{Binding IsImage}">
                                <Border BackgroundColor="{StaticResource CoalSurface}"
                                        StrokeThickness="0" Padding="8"
                                        HorizontalOptions="{Binding BubbleAlign}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <StackLayout Spacing="6">
                                        <Label Text="{Binding Text}"
                                               FontSize="11" TextColor="{StaticResource SeaShellMuted}"
                                               LineBreakMode="TailTruncation" />
                                        <Image Source="{Binding ImageBytes, Converter={StaticResource ByteArrayToImageSourceConverter}}"
                                               HeightRequest="220" WidthRequest="220"
                                               Aspect="AspectFill">
                                            <Image.Clip>
                                                <RoundRectangleGeometry CornerRadius="8"
                                                    Rect="0,0,220,220" />
                                            </Image.Clip>
                                        </Image>
                                    </StackLayout>
                                </Border>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Message input bar (wide/desktop) -->
            <Grid x:Name="MessageBarWide" Grid.Row="4" Padding="12,8,10,8"
                  ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                  ColumnSpacing="6" BackgroundColor="{StaticResource CoalPanel}">
                <BoxView Grid.ColumnSpan="5" HeightRequest="1"
                         Color="{StaticResource CoalBorder}" VerticalOptions="Start" />
                <Button Grid.Column="0" Text="📎" Clicked="OnSendTestFileClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShellMuted}"
                        FontSize="16" Padding="10,6" CornerRadius="8"
                        HeightRequest="38" WidthRequest="42" />
                <Button Grid.Column="1" Text="🖼" Clicked="OnSendPhotoClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShellMuted}"
                        FontSize="16" Padding="10,6" CornerRadius="8"
                        HeightRequest="38" WidthRequest="42" />
                <Border Grid.Column="2"
                        BackgroundColor="{StaticResource CoalSurface}"
                        StrokeThickness="1" Stroke="{StaticResource CoalBorder}"
                        Padding="4,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Entry x:Name="MessageEntry" Placeholder="Message..."
                           BackgroundColor="Transparent"
                           TextColor="{StaticResource SeaShell}"
                           PlaceholderColor="{StaticResource SeaShellMuted}"
                           FontSize="{OnIdiom Phone=13, Default=13}"
                           Completed="OnSendClicked" />
                </Border>
                <Button Grid.Column="3" Text="🗑" Clicked="OnClearChatClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShellMuted}"
                        FontSize="14" Padding="8,6" CornerRadius="8"
                        HeightRequest="38" WidthRequest="42" />
                <Button Grid.Column="4" Text="➤" Clicked="OnSendClicked"
                        BackgroundColor="{StaticResource AccentBlue}"
                        TextColor="White"
                        FontSize="18" Padding="12,6" CornerRadius="8"
                        HeightRequest="38" WidthRequest="48" />
            </Grid>

            <!-- Message input bar (narrow/mobile) -->
            <VerticalStackLayout x:Name="MessageBarNarrow" Grid.Row="4" IsVisible="False"
                                 Padding="10,8" Spacing="8"
                                 BackgroundColor="{StaticResource CoalPanel}">
                <BoxView HeightRequest="1" Color="{StaticResource CoalBorder}" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Border Grid.Column="0"
                            BackgroundColor="{StaticResource CoalSurface}"
                            StrokeThickness="1" Stroke="{StaticResource CoalBorder}"
                            Padding="8,0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Entry x:Name="MessageEntryNarrow" Placeholder="Message..."
                               BackgroundColor="Transparent"
                               TextColor="{StaticResource SeaShell}"
                               PlaceholderColor="{StaticResource SeaShellMuted}"
                               FontSize="14" MinimumHeightRequest="44"
                               Completed="OnSendClicked" />
                    </Border>
                    <Button Grid.Column="1" Text="➤" Clicked="OnSendClicked"
                            BackgroundColor="{StaticResource AccentBlue}"
                            TextColor="White"
                            FontSize="18" Padding="14,10" CornerRadius="10"
                            HeightRequest="44" />
                </Grid>
                <HorizontalStackLayout Spacing="8">
                    <Button Text="📎" Clicked="OnSendTestFileClicked"
                            BackgroundColor="{StaticResource CoalSurface}"
                            TextColor="{StaticResource SeaShellMuted}"
                            FontSize="18" Padding="12,8" CornerRadius="10" />
                    <Button Text="🖼" Clicked="OnSendPhotoClicked"
                            BackgroundColor="{StaticResource CoalSurface}"
                            TextColor="{StaticResource SeaShellMuted}"
                            FontSize="18" Padding="12,8" CornerRadius="10" />
                    <Button Text="🗑" Clicked="OnClearChatClicked"
                            BackgroundColor="{StaticResource CoalSurface}"
                            TextColor="{StaticResource SeaShellMuted}"
                            FontSize="18" Padding="12,8" CornerRadius="10" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- File transfer status row -->
            <Grid x:Name="FileStatusBar" Grid.Row="5" Padding="12,5,10,5"
                  ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="4"
                  BackgroundColor="{StaticResource CoalPanel}">
                <BoxView Grid.ColumnSpan="5" HeightRequest="1"
                         Color="{StaticResource CoalBorder}" VerticalOptions="Start" />
                <Label Grid.Column="0" x:Name="FileTransferLabel" Text="File: idle"
                       FontSize="9" TextColor="{StaticResource SeaShellMuted}" VerticalOptions="Center" />
                <Button Grid.Column="1" Text="Resume" Clicked="OnResumeFileClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShellMuted}"
                        FontSize="9" Padding="6,2" CornerRadius="4" />
                <Label Grid.Column="2" x:Name="LogCountLabel" Text=""
                       FontSize="9" TextColor="{StaticResource SeaShellMuted}" VerticalOptions="Center" />
                <Button Grid.Column="3" Text="Copy" Clicked="OnCopyLogsClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShellMuted}"
                        FontSize="9" Padding="6,2" CornerRadius="4" />
                <Button Grid.Column="4" x:Name="ClearLogsBtn" Text="Clear" Clicked="OnClearLogsClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShellMuted}"
                        FontSize="9" Padding="6,2" CornerRadius="4" />
            </Grid>

            <!-- Diagnostics panel -->
            <Grid x:Name="DiagnosticsPanel" Grid.Row="6"
                  RowDefinitions="Auto,Auto,*" BackgroundColor="{StaticResource CoalPanel}">
                <BoxView Grid.Row="0" HeightRequest="1" Color="{StaticResource CoalBorder}" />
                <!-- Metrics bar -->
                <Grid Grid.Row="1" Padding="12,6,12,6"
                      ColumnDefinitions="*,*,*,*" ColumnSpacing="6"
                      BackgroundColor="{StaticResource CoalPanel}">
                    <Border Grid.Column="0" BackgroundColor="{StaticResource CoalSurface}"
                            StrokeThickness="0" Padding="8,5">
                        <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                        <StackLayout Spacing="1">
                            <Label Text="RTT" FontSize="8" TextColor="{StaticResource SeaShellMuted}" />
                            <Label x:Name="MetricRttLabel" Text="--" FontSize="12"
                                   FontAttributes="Bold" TextColor="{StaticResource AccentBlue}" />
                        </StackLayout>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="{StaticResource CoalSurface}"
                            StrokeThickness="0" Padding="8,5">
                        <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                        <StackLayout Spacing="1">
                            <Label Text="LOSS" FontSize="8" TextColor="{StaticResource SeaShellMuted}" />
                            <Label x:Name="MetricLossLabel" Text="--" FontSize="12"
                                   FontAttributes="Bold" TextColor="{StaticResource AccentGreen}" />
                        </StackLayout>
                    </Border>
                    <Border Grid.Column="2" BackgroundColor="{StaticResource CoalSurface}"
                            StrokeThickness="0" Padding="8,5">
                        <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                        <StackLayout Spacing="1">
                            <Label Text="QUALITY" FontSize="8" TextColor="{StaticResource SeaShellMuted}" />
                            <Label x:Name="MetricQualityLabel" Text="--" FontSize="12"
                                   FontAttributes="Bold" TextColor="{StaticResource AccentGreen}" />
                        </StackLayout>
                    </Border>
                    <Border Grid.Column="3" BackgroundColor="{StaticResource CoalSurface}"
                            StrokeThickness="0" Padding="8,5">
                        <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                        <StackLayout Spacing="1">
                            <Label Text="RETRIES" FontSize="8" TextColor="{StaticResource SeaShellMuted}" />
                            <Label x:Name="MetricRetriesLabel" Text="--" FontSize="12"
                                   FontAttributes="Bold" TextColor="{StaticResource AccentAmber}" />
                        </StackLayout>
                    </Border>
                </Grid>
                <ScrollView Grid.Row="2" x:Name="TechLogScrollView" Padding="12,6">
                    <VerticalStackLayout x:Name="TechLogStack" Spacing="1" />
                </ScrollView>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
