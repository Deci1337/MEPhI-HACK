<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MassangerMaximka"
             xmlns:conv="clr-namespace:MassangerMaximka.Converters"
             x:Class="MassangerMaximka.MainPage"
             Title="PHOTON"
             BackgroundColor="{StaticResource Coal}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:ByteArrayToImageSourceConverter x:Key="ByteArrayToImageSourceConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid x:Name="RootLayout" ColumnSpacing="0" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{OnIdiom Phone=0, Default=280}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ====== LEFT: Peers sidebar ====== -->
        <Grid x:Name="SidebarPanel" Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
              BackgroundColor="{StaticResource CoalPanel}"
              RowDefinitions="Auto,Auto,*,Auto" RowSpacing="0">

            <!-- App header -->
            <Grid Grid.Row="0" Padding="20,24,20,16" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <!-- Logo -->
                <Border Grid.Column="0"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        HeightRequest="40" WidthRequest="40"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Label Text="P" FontFamily="OpenSansSemibold" FontSize="20" TextColor="Black" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Text="PHOTON" FontFamily="OpenSansSemibold" FontSize="16" FontAttributes="Bold"
                           TextColor="White" CharacterSpacing="1.5" />
                    <Label x:Name="StatusLabel" Text="Starting..." FontSize="11"
                           TextColor="{StaticResource SeaShellMuted}" />
                </StackLayout>
            </Grid>
            <BoxView Grid.Row="0" HeightRequest="1" Color="{StaticResource CoalBorder}" VerticalOptions="End" />

            <!-- Peers section header -->
            <Grid Grid.Row="1" Padding="20,16,20,8" ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" x:Name="PeersLabel" Text="DEVICES"
                       FontSize="11" FontAttributes="Bold" TextColor="{StaticResource SeaShellMuted}"
                       CharacterSpacing="1.2" VerticalOptions="Center" />
                <Label Grid.Column="1" x:Name="PortHintLabel" Text=""
                       FontSize="10" TextColor="{StaticResource SeaShellMuted}" VerticalOptions="Center" />
            </Grid>

            <!-- Peers list -->
            <CollectionView Grid.Row="2" x:Name="PeersList" SelectionMode="Single"
                            SelectionChanged="OnPeerSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Grid Padding="16,6,16,6" MinimumHeightRequest="{OnIdiom Phone=56, Default=50}">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer NumberOfTapsRequired="2" Tapped="OnPeerDoubleTapped" />
                            </Grid.GestureRecognizers>
                            <Border BackgroundColor="{StaticResource CoalSurface}"
                                    StrokeThickness="1" Stroke="{StaticResource CoalBorder}" Padding="12,10">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <!-- Avatar circle -->
                                    <Border Grid.Column="0" WidthRequest="36" HeightRequest="36"
                                            BackgroundColor="{StaticResource CoalInput}"
                                            StrokeThickness="1" Stroke="{StaticResource CoalBorder}" VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="18" />
                                        </Border.StrokeShape>
                                        <Label FontSize="14" FontAttributes="Bold"
                                               TextColor="White"
                                               HorizontalOptions="Center" VerticalOptions="Center">
                                            <Label.Text>
                                                <Binding Path="." StringFormat="{}{0}" />
                                            </Label.Text>
                                        </Label>
                                    </Border>
                                    <!-- Name + status -->
                                    <Label Grid.Column="1" Text="{Binding}"
                                           FontSize="{OnIdiom Phone=13, Default=13}"
                                           TextColor="White"
                                           LineBreakMode="TailTruncation"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Connect + actions section -->
            <StackLayout Grid.Row="3" Padding="16,12,16,20" Spacing="8">
                <BoxView HeightRequest="1" Color="{StaticResource CoalBorder}" />
                <Border BackgroundColor="{StaticResource CoalInput}"
                        StrokeThickness="1" Stroke="{StaticResource CoalBorder}"
                        Padding="12,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6" />
                    </Border.StrokeShape>
                    <Entry x:Name="ManualIpEntry" Placeholder="192.168.1.x:45680"
                           FontSize="{OnIdiom Phone=12, Default=13}"
                           BackgroundColor="Transparent"
                           TextColor="White"
                           PlaceholderColor="{StaticResource SeaShellMuted}" />
                </Border>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Grid.Column="0" Text="CONNECT" Clicked="OnConnectClicked"
                            BackgroundColor="White"
                            TextColor="Black" FontAttributes="Bold"
                            FontSize="11" Padding="0,10" CornerRadius="6" />
                    <Button Grid.Column="1" Text="FORGET" Clicked="OnForgetSavedPeersClicked"
                            BackgroundColor="Transparent"
                            BorderColor="{StaticResource CoalBorder}" BorderWidth="1"
                            TextColor="{StaticResource SeaShellMuted}" FontAttributes="Bold"
                            FontSize="11" Padding="0,10" CornerRadius="6" />
                </Grid>
                <Button Text="+ NEW CHANNEL" Clicked="OnCreateChannelClicked"
                        BackgroundColor="Transparent"
                        BorderColor="White" BorderWidth="1"
                        TextColor="White" FontAttributes="Bold"
                        FontSize="11" Padding="0,10" CornerRadius="6" />
            </StackLayout>
        </Grid>

        <!-- Vertical divider (desktop only) -->
        <BoxView x:Name="SidebarDivider" Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                 WidthRequest="1" Color="{StaticResource CoalBorder}" HorizontalOptions="End" />

        <!-- ====== RIGHT: Chat panel ====== -->
        <Grid x:Name="ChatPanel" Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
              BackgroundColor="{StaticResource Coal}"
              RowDefinitions="Auto,Auto,Auto,*,Auto,Auto,200" RowSpacing="0">

            <!-- Chat header -->
            <Grid Grid.Row="0" Padding="16,12,12,12"
                  ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto"
                  ColumnSpacing="10"
                  BackgroundColor="{StaticResource CoalPanel}">
                <!-- Mobile back button -->
                <Button Grid.Column="0" x:Name="BackToPeersBtn" Text="❮"
                        Clicked="OnBackToPeersClicked"
                        IsVisible="False"
                        BackgroundColor="Transparent"
                        BorderColor="{StaticResource CoalBorder}" BorderWidth="1"
                        TextColor="White"
                        FontSize="18" Padding="12,6" CornerRadius="6"
                        HeightRequest="40" />
                <!-- Peer info -->
                <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label x:Name="SelectedPeerLabel" Text="Select a device"
                           FontSize="{OnIdiom Phone=15, Default=16}" FontAttributes="Bold"
                           TextColor="White" />
                    <Label x:Name="VoiceStatusLabel" Text="Voice: idle"
                           FontSize="11" TextColor="{StaticResource SeaShellMuted}" />
                </StackLayout>
                <!-- Voice record button -->
                <Button Grid.Column="2" x:Name="RecordBtn" Text="⬤"
                        Clicked="OnRecordVoiceClicked"
                        BackgroundColor="White"
                        TextColor="Black"
                        FontSize="14" Padding="12,8" CornerRadius="6"
                        HeightRequest="40" WidthRequest="48" />
                <!-- Stop button -->
                <Button Grid.Column="3" x:Name="StopSendBtn" Text="⬛"
                        Clicked="OnStopSendVoiceClicked"
                        BackgroundColor="Transparent"
                        BorderColor="{StaticResource CoalBorder}" BorderWidth="1"
                        TextColor="White"
                        FontSize="14" Padding="12,8" CornerRadius="6"
                        HeightRequest="40" WidthRequest="48" />
                <!-- PTT button -->
                <Button Grid.Column="4" x:Name="PttBtn" Text="🎤 HOLD TO TALK"
                        IsVisible="False"
                        Pressed="OnPttPressed" Released="OnPttReleased"
                        BackgroundColor="White"
                        TextColor="Black" FontAttributes="Bold"
                        FontSize="12" Padding="16,8" CornerRadius="6"
                        HeightRequest="40" />
                <!-- Call button -->
                <Button Grid.Column="5" x:Name="CallBtn" Text="☏"
                        Clicked="OnCallButtonClicked"
                        BackgroundColor="Transparent"
                        BorderColor="White" BorderWidth="1"
                        TextColor="White"
                        FontSize="18" Padding="12,6" CornerRadius="6"
                        HeightRequest="40" WidthRequest="48" />
            </Grid>
            <BoxView Grid.Row="0" HeightRequest="1" Color="{StaticResource CoalBorder}" VerticalOptions="End" />

            <!-- Channel bar -->
            <Grid Grid.Row="1" x:Name="ChannelBar" IsVisible="False"
                  BackgroundColor="{StaticResource CoalSurface}" Padding="16,10,12,10"
                  ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                <Label Grid.Column="0" Text="#" FontSize="18" TextColor="White"
                       VerticalOptions="Center" />
                <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label x:Name="ChannelInfoLabel" Text="Channel"
                           TextColor="White" FontSize="13" FontAttributes="Bold" />
                    <Label x:Name="ChannelPttLabel" IsVisible="False"
                           TextColor="White" FontSize="11" FontAttributes="Bold" />
                </StackLayout>
                <Button Grid.Column="2" Text="+ INVITE" Clicked="OnInviteToChannelClicked"
                        BackgroundColor="Transparent"
                        BorderColor="{StaticResource CoalBorder}" BorderWidth="1"
                        TextColor="White" FontAttributes="Bold"
                        FontSize="10" Padding="12,6" CornerRadius="4" />
                <Button Grid.Column="3" x:Name="LeaveChannelBtn" Text="LEAVE"
                        Clicked="OnLeaveChannelClicked"
                        BackgroundColor="White"
                        TextColor="Black" FontAttributes="Bold"
                        FontSize="10" Padding="12,6" CornerRadius="4" />
            </Grid>

            <!-- Incoming call banner -->
            <Border Grid.Row="2" x:Name="IncomingCallBanner" IsVisible="False"
                    BackgroundColor="{StaticResource CoalSurface}" StrokeThickness="1" Stroke="White" Margin="16,16,16,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid Padding="16,14,14,14" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                    <Label Grid.Column="0" Text="☏" FontSize="24" TextColor="White" VerticalOptions="Center" />
                    <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="INCOMING CALL" FontSize="10" FontAttributes="Bold" CharacterSpacing="1"
                               TextColor="{StaticResource SeaShellMuted}" />
                        <Label x:Name="IncomingCallLabel" Text="Unknown"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="White" />
                    </StackLayout>
                    <Button Grid.Column="2" Text="ACCEPT" Clicked="OnAcceptCallClicked"
                            BackgroundColor="White"
                            TextColor="Black" FontAttributes="Bold" FontSize="11"
                            Padding="16,8" CornerRadius="6" />
                    <Button Grid.Column="3" Text="DECLINE" Clicked="OnDeclineCallClicked"
                            BackgroundColor="Transparent" BorderColor="{StaticResource CoalBorder}" BorderWidth="1"
                            TextColor="White" FontAttributes="Bold" FontSize="11"
                            Padding="16,8" CornerRadius="6" />
                </Grid>
            </Border>

            <!-- Chat messages -->
            <CollectionView Grid.Row="3" x:Name="ChatList" Margin="16,12,16,12">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:ChatItem">
                        <Grid Padding="0,4">
                            <!-- Text bubble -->
                            <Grid IsVisible="{Binding IsText}">
                                <Border BackgroundColor="{Binding BubbleBg}"
                                        StrokeThickness="{Binding BubbleStrokeThickness}"
                                        Stroke="{StaticResource CoalBorder}"
                                        Padding="{Binding BubblePadding}"
                                        MaximumWidthRequest="500"
                                        HorizontalOptions="{Binding BubbleAlign}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="{Binding BubbleRadius}" />
                                    </Border.StrokeShape>
                                    <StackLayout Spacing="4">
                                        <Label Text="{Binding Text}"
                                               LineBreakMode="WordWrap"
                                               FontSize="{OnIdiom Phone=14, Default=14}"
                                               TextColor="{Binding BubbleTextColor}" />
                                        <Label Text="{Binding Status}"
                                               IsVisible="{Binding HasStatus}"
                                               FontSize="10" TextColor="{StaticResource SeaShellMuted}"
                                               HorizontalOptions="End" />
                                    </StackLayout>
                                </Border>
                            </Grid>
                            <!-- Voice message -->
                            <Grid IsVisible="{Binding IsVoice}">
                                <Border BackgroundColor="{Binding BubbleBg}"
                                        StrokeThickness="{Binding BubbleStrokeThickness}"
                                        Stroke="{StaticResource CoalBorder}"
                                        Padding="12,10"
                                        HorizontalOptions="{Binding BubbleAlign}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="{Binding BubbleRadius}" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                        <Button Grid.Column="0" Text="▶"
                                                BackgroundColor="Transparent"
                                                BorderColor="{Binding BubbleTextColor}" BorderWidth="1"
                                                TextColor="{Binding BubbleTextColor}"
                                                FontSize="14" Padding="12,6" CornerRadius="6"
                                                CommandParameter="{Binding VoicePath}"
                                                Clicked="OnVoiceItemPlayClicked" />
                                        <Label Grid.Column="1" Text="{Binding Text}"
                                               FontSize="13" TextColor="{Binding BubbleTextColor}"
                                               VerticalOptions="Center" LineBreakMode="TailTruncation" />
                                    </Grid>
                                </Border>
                            </Grid>
                            <!-- Image message -->
                            <Grid IsVisible="{Binding IsImage}">
                                <Border BackgroundColor="{Binding BubbleBg}"
                                        StrokeThickness="{Binding BubbleStrokeThickness}"
                                        Stroke="{StaticResource CoalBorder}"
                                        Padding="8"
                                        HorizontalOptions="{Binding BubbleAlign}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="{Binding BubbleRadius}" />
                                    </Border.StrokeShape>
                                    <StackLayout Spacing="8">
                                        <Label Text="{Binding Text}"
                                               FontSize="12" TextColor="{Binding BubbleTextColor}"
                                               LineBreakMode="TailTruncation" />
                                        <Image Source="{Binding ImageBytes, Converter={StaticResource ByteArrayToImageSourceConverter}}"
                                               HeightRequest="240" WidthRequest="240"
                                               Aspect="AspectFill">
                                            <Image.Clip>
                                                <RoundRectangleGeometry CornerRadius="8" Rect="0,0,240,240" />
                                            </Image.Clip>
                                        </Image>
                                    </StackLayout>
                                </Border>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Message input bar (wide/desktop) -->
            <Grid x:Name="MessageBarWide" Grid.Row="4" Padding="16,12,16,12"
                  ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                  ColumnSpacing="8" BackgroundColor="{StaticResource CoalPanel}">
                <BoxView Grid.ColumnSpan="5" HeightRequest="1"
                         Color="{StaticResource CoalBorder}" VerticalOptions="Start" />
                <Button Grid.Column="0" Text="📎" Clicked="OnSendTestFileClicked"
                        BackgroundColor="Transparent"
                        BorderColor="{StaticResource CoalBorder}" BorderWidth="1"
                        TextColor="White"
                        FontSize="16" Padding="12,8" CornerRadius="6"
                        HeightRequest="42" WidthRequest="46" />
                <Button Grid.Column="1" Text="🖼" Clicked="OnSendPhotoClicked"
                        BackgroundColor="Transparent"
                        BorderColor="{StaticResource CoalBorder}" BorderWidth="1"
                        TextColor="White"
                        FontSize="16" Padding="12,8" CornerRadius="6"
                        HeightRequest="42" WidthRequest="46" />
                <Border Grid.Column="2"
                        BackgroundColor="{StaticResource CoalInput}"
                        StrokeThickness="1" Stroke="{StaticResource CoalBorder}"
                        Padding="12,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6" />
                    </Border.StrokeShape>
                    <Entry x:Name="MessageEntry" Placeholder="Type a message..."
                           BackgroundColor="Transparent"
                           TextColor="White"
                           PlaceholderColor="{StaticResource SeaShellMuted}"
                           FontSize="{OnIdiom Phone=14, Default=14}"
                           Completed="OnSendClicked" />
                </Border>
                <Button Grid.Column="3" Text="✕" Clicked="OnClearChatClicked"
                        BackgroundColor="Transparent"
                        BorderColor="{StaticResource CoalBorder}" BorderWidth="1"
                        TextColor="{StaticResource SeaShellMuted}"
                        FontSize="14" Padding="12,8" CornerRadius="6"
                        HeightRequest="42" WidthRequest="46" />
                <Button Grid.Column="4" Text="➔" Clicked="OnSendClicked"
                        BackgroundColor="White"
                        TextColor="Black"
                        FontSize="18" Padding="16,8" CornerRadius="6"
                        HeightRequest="42" WidthRequest="54" />
            </Grid>

            <!-- Message input bar (narrow/mobile) -->
            <VerticalStackLayout x:Name="MessageBarNarrow" Grid.Row="4" IsVisible="False"
                                 Padding="12,10" Spacing="10"
                                 BackgroundColor="{StaticResource CoalPanel}">
                <BoxView HeightRequest="1" Color="{StaticResource CoalBorder}" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Border Grid.Column="0"
                            BackgroundColor="{StaticResource CoalInput}"
                            StrokeThickness="1" Stroke="{StaticResource CoalBorder}"
                            Padding="12,0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="6" />
                        </Border.StrokeShape>
                        <Entry x:Name="MessageEntryNarrow" Placeholder="Message..."
                               BackgroundColor="Transparent"
                               TextColor="White"
                               PlaceholderColor="{StaticResource SeaShellMuted}"
                               FontSize="15" MinimumHeightRequest="48"
                               Completed="OnSendClicked" />
                    </Border>
                    <Button Grid.Column="1" Text="➔" Clicked="OnSendClicked"
                            BackgroundColor="White"
                            TextColor="Black"
                            FontSize="20" Padding="16,10" CornerRadius="6"
                            HeightRequest="48" />
                </Grid>
                <HorizontalStackLayout Spacing="10">
                    <Button Text="📎" Clicked="OnSendTestFileClicked"
                            BackgroundColor="Transparent" BorderColor="{StaticResource CoalBorder}" BorderWidth="1"
                            TextColor="White"
                            FontSize="18" Padding="16,10" CornerRadius="6" />
                    <Button Text="🖼" Clicked="OnSendPhotoClicked"
                            BackgroundColor="Transparent" BorderColor="{StaticResource CoalBorder}" BorderWidth="1"
                            TextColor="White"
                            FontSize="18" Padding="16,10" CornerRadius="6" />
                    <Button Text="✕" Clicked="OnClearChatClicked"
                            BackgroundColor="Transparent" BorderColor="{StaticResource CoalBorder}" BorderWidth="1"
                            TextColor="{StaticResource SeaShellMuted}"
                            FontSize="18" Padding="16,10" CornerRadius="6" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- File transfer status row -->
            <Grid x:Name="FileStatusBar" Grid.Row="5" Padding="16,6,12,6"
                  ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="6"
                  BackgroundColor="{StaticResource CoalPanel}">
                <BoxView Grid.ColumnSpan="5" HeightRequest="1"
                         Color="{StaticResource CoalBorder}" VerticalOptions="Start" />
                <Label Grid.Column="0" x:Name="FileTransferLabel" Text="File: idle"
                       FontSize="10" TextColor="{StaticResource SeaShellMuted}" VerticalOptions="Center" />
                <Button Grid.Column="1" Text="RESUME" Clicked="OnResumeFileClicked"
                        BackgroundColor="Transparent" BorderColor="{StaticResource CoalBorder}" BorderWidth="1"
                        TextColor="White" FontAttributes="Bold"
                        FontSize="9" Padding="8,4" CornerRadius="4" />
                <Label Grid.Column="2" x:Name="LogCountLabel" Text=""
                       FontSize="10" TextColor="{StaticResource SeaShellMuted}" VerticalOptions="Center" />
                <Button Grid.Column="3" Text="COPY" Clicked="OnCopyLogsClicked"
                        BackgroundColor="Transparent" BorderColor="{StaticResource CoalBorder}" BorderWidth="1"
                        TextColor="White" FontAttributes="Bold"
                        FontSize="9" Padding="8,4" CornerRadius="4" />
                <Button Grid.Column="4" x:Name="ClearLogsBtn" Text="CLEAR" Clicked="OnClearLogsClicked"
                        BackgroundColor="Transparent" BorderColor="{StaticResource CoalBorder}" BorderWidth="1"
                        TextColor="White" FontAttributes="Bold"
                        FontSize="9" Padding="8,4" CornerRadius="4" />
            </Grid>

            <!-- Diagnostics panel -->
            <Grid x:Name="DiagnosticsPanel" Grid.Row="6"
                  RowDefinitions="Auto,Auto,*" BackgroundColor="{StaticResource CoalPanel}">
                <BoxView Grid.Row="0" HeightRequest="1" Color="{StaticResource CoalBorder}" />
                <!-- Metrics bar -->
                <Grid Grid.Row="1" Padding="16,8,16,8"
                      ColumnDefinitions="*,*,*,*" ColumnSpacing="8"
                      BackgroundColor="{StaticResource CoalPanel}">
                    <Border Grid.Column="0" BackgroundColor="{StaticResource CoalSurface}"
                            StrokeThickness="1" Stroke="{StaticResource CoalBorder}" Padding="10,6">
                        <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                        <StackLayout Spacing="2">
                            <Label Text="RTT" FontSize="9" TextColor="{StaticResource SeaShellMuted}" FontAttributes="Bold" CharacterSpacing="1" />
                            <Label x:Name="MetricRttLabel" Text="--" FontSize="13"
                                   FontAttributes="Bold" TextColor="White" />
                        </StackLayout>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="{StaticResource CoalSurface}"
                            StrokeThickness="1" Stroke="{StaticResource CoalBorder}" Padding="10,6">
                        <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                        <StackLayout Spacing="2">
                            <Label Text="LOSS" FontSize="9" TextColor="{StaticResource SeaShellMuted}" FontAttributes="Bold" CharacterSpacing="1" />
                            <Label x:Name="MetricLossLabel" Text="--" FontSize="13"
                                   FontAttributes="Bold" TextColor="White" />
                        </StackLayout>
                    </Border>
                    <Border Grid.Column="2" BackgroundColor="{StaticResource CoalSurface}"
                            StrokeThickness="1" Stroke="{StaticResource CoalBorder}" Padding="10,6">
                        <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                        <StackLayout Spacing="2">
                            <Label Text="QUALITY" FontSize="9" TextColor="{StaticResource SeaShellMuted}" FontAttributes="Bold" CharacterSpacing="1" />
                            <Label x:Name="MetricQualityLabel" Text="--" FontSize="13"
                                   FontAttributes="Bold" TextColor="White" />
                        </StackLayout>
                    </Border>
                    <Border Grid.Column="3" BackgroundColor="{StaticResource CoalSurface}"
                            StrokeThickness="1" Stroke="{StaticResource CoalBorder}" Padding="10,6">
                        <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                        <StackLayout Spacing="2">
                            <Label Text="RETRIES" FontSize="9" TextColor="{StaticResource SeaShellMuted}" FontAttributes="Bold" CharacterSpacing="1" />
                            <Label x:Name="MetricRetriesLabel" Text="--" FontSize="13"
                                   FontAttributes="Bold" TextColor="White" />
                        </StackLayout>
                    </Border>
                </Grid>
                <ScrollView Grid.Row="2" x:Name="TechLogScrollView" Padding="16,8">
                    <VerticalStackLayout x:Name="TechLogStack" Spacing="2" />
                </ScrollView>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
