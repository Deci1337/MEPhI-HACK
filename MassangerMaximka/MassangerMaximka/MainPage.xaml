<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MassangerMaximka"
             x:Class="MassangerMaximka.MainPage"
             Title="PHOTON"
             BackgroundColor="{StaticResource Coal}">

    <!-- Two-column on Desktop, stacked on Phone -->
    <Grid ColumnSpacing="0" RowSpacing="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{OnIdiom Phone=100, Default=220}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ====== LEFT: Peers sidebar ====== -->
        <Grid Grid.Column="0" BackgroundColor="{StaticResource CoalPanel}"
              RowDefinitions="Auto,Auto,*,Auto" RowSpacing="0">

            <!-- Sidebar header -->
            <StackLayout Grid.Row="0" Padding="10,14,10,10" Spacing="2">
                <Label Text="PHOTON" FontSize="{OnIdiom Phone=13, Default=16}"
                       FontAttributes="Bold" TextColor="{StaticResource SeaShell}" />
                <Label x:Name="StatusLabel" Text="Starting..." FontSize="9"
                       TextColor="{StaticResource SeaShellMuted}" />
                <Label x:Name="PortHintLabel" Text="" FontSize="8"
                       TextColor="{StaticResource SeaShellMuted}" />
            </StackLayout>
            <BoxView Grid.Row="0" HeightRequest="1" Color="{StaticResource CoalBorder}" VerticalOptions="End" />

            <!-- Peers count -->
            <Label Grid.Row="1" x:Name="PeersLabel" Text="Peers: 0"
                   FontSize="9" TextColor="{StaticResource SeaShellMuted}"
                   Padding="10,6,10,2" />

            <!-- Peers list -->
            <CollectionView Grid.Row="2" x:Name="PeersList" SelectionMode="Single"
                            SelectionChanged="OnPeerSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Grid Padding="{OnIdiom Phone='6,8', Default='10,10'}" BackgroundColor="Transparent">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer NumberOfTapsRequired="2" Tapped="OnPeerDoubleTapped" />
                            </Grid.GestureRecognizers>
                            <Label Text="{Binding}" FontSize="{OnIdiom Phone=10, Default=12}"
                                   TextColor="{StaticResource SeaShell}"
                                   LineBreakMode="TailTruncation" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Connect section -->
            <StackLayout Grid.Row="3" Padding="6,6,6,10" Spacing="5">
                <BoxView HeightRequest="1" Color="{StaticResource CoalBorder}" />
                <Entry x:Name="ManualIpEntry" Placeholder="IP:port"
                       FontSize="{OnIdiom Phone=10, Default=11}"
                       BackgroundColor="{StaticResource CoalInput}"
                       TextColor="{StaticResource SeaShell}"
                       PlaceholderColor="{StaticResource SeaShellMuted}" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="4">
                    <Button Grid.Column="0" Text="Connect" Clicked="OnConnectClicked"
                            BackgroundColor="{StaticResource CoalSurface}"
                            TextColor="{StaticResource SeaShell}"
                            FontSize="{OnIdiom Phone=9, Default=10}" Padding="0,6" CornerRadius="3" />
                    <Button Grid.Column="1" Text="Forget" Clicked="OnForgetSavedPeersClicked"
                            BackgroundColor="{StaticResource DangerRed}"
                            TextColor="{StaticResource SeaShell}"
                            FontSize="{OnIdiom Phone=9, Default=10}" Padding="0,6" CornerRadius="3" />
                </Grid>
            </StackLayout>
        </Grid>

        <!-- Vertical divider -->
        <BoxView Grid.Column="0" WidthRequest="1" Color="{StaticResource CoalBorder}" HorizontalOptions="End" />

        <!-- ====== RIGHT: Chat panel ====== -->
        <Grid Grid.Column="1" BackgroundColor="{StaticResource Coal}"
              RowDefinitions="Auto,Auto,3*,Auto,Auto,2*" RowSpacing="0">

            <!-- Chat header: selected peer + call controls -->
            <Grid Grid.Row="0" Padding="12,9,8,9"
                  ColumnDefinitions="*,Auto,Auto,Auto"
                  ColumnSpacing="6"
                  BackgroundColor="{StaticResource CoalPanel}">
                <StackLayout Grid.Column="0" Spacing="1" VerticalOptions="Center">
                    <Label x:Name="SelectedPeerLabel" Text="Select a peer"
                           FontSize="{OnIdiom Phone=12, Default=14}" FontAttributes="Bold"
                           TextColor="{StaticResource SeaShell}" />
                    <Label x:Name="VoiceStatusLabel" Text="Voice: idle"
                           FontSize="9" TextColor="{StaticResource SeaShellMuted}" />
                </StackLayout>
                <Button Grid.Column="1" x:Name="RecordBtn" Text="REC"
                        Clicked="OnRecordVoiceClicked"
                        BackgroundColor="{StaticResource DangerRed}"
                        TextColor="{StaticResource SeaShell}"
                        FontSize="10" Padding="8,4" CornerRadius="3" />
                <Button Grid.Column="2" Text="STOP"
                        Clicked="OnStopSendVoiceClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShell}"
                        FontSize="10" Padding="8,4" CornerRadius="3" />
                <Button Grid.Column="3" x:Name="CallBtn" Text="Call"
                        Clicked="OnCallButtonClicked"
                        BackgroundColor="{StaticResource SuccessGreen}"
                        TextColor="{StaticResource SeaShell}"
                        FontSize="10" Padding="10,4" CornerRadius="3" />
            </Grid>
            <BoxView Grid.Row="0" HeightRequest="1" Color="{StaticResource CoalBorder}" VerticalOptions="End" />

            <!-- Incoming call banner -->
            <Frame Grid.Row="1" x:Name="IncomingCallBanner" IsVisible="False"
                   BackgroundColor="#182A1A" BorderColor="{StaticResource SuccessGreen}"
                   Padding="10,6" CornerRadius="0" Margin="0">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <Label Grid.Column="0" x:Name="IncomingCallLabel" Text="Incoming call..."
                           TextColor="{StaticResource SeaShell}" FontSize="12"
                           FontAttributes="Bold" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="Accept" Clicked="OnAcceptCallClicked"
                            BackgroundColor="{StaticResource SuccessGreen}"
                            TextColor="{StaticResource SeaShell}" FontSize="10" Padding="12,4" CornerRadius="3" />
                    <Button Grid.Column="2" Text="Decline" Clicked="OnDeclineCallClicked"
                            BackgroundColor="{StaticResource DangerRed}"
                            TextColor="{StaticResource SeaShell}" FontSize="10" Padding="12,4" CornerRadius="3" />
                </Grid>
            </Frame>

            <!-- Chat messages -->
            <CollectionView Grid.Row="2" x:Name="ChatList" Margin="0" Padding="10,6">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:ChatItem">
                        <Grid Padding="2,3">
                            <!-- Text message -->
                            <Label Text="{Binding Text}"
                                   IsVisible="{Binding IsText}"
                                   LineBreakMode="WordWrap"
                                   FontSize="{OnIdiom Phone=12, Default=13}"
                                   TextColor="{StaticResource SeaShell}" />
                            <!-- Voice message -->
                            <Grid IsVisible="{Binding IsVoice}"
                                  ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Button Grid.Column="0" Text="Play"
                                        BackgroundColor="{StaticResource AccentBlue}"
                                        TextColor="{StaticResource SeaShell}"
                                        FontSize="10" Padding="10,4" CornerRadius="3"
                                        CommandParameter="{Binding VoicePath}"
                                        Clicked="OnVoiceItemPlayClicked" />
                                <Label Grid.Column="1" Text="{Binding Text}"
                                       FontSize="11" TextColor="{StaticResource SeaShellMuted}"
                                       VerticalOptions="Center" LineBreakMode="TailTruncation" />
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Message input bar -->
            <Grid Grid.Row="3" Padding="8,6" ColumnDefinitions="Auto,*,Auto,Auto"
                  ColumnSpacing="6" BackgroundColor="{StaticResource CoalPanel}">
                <BoxView Grid.ColumnSpan="4" HeightRequest="1" Color="{StaticResource CoalBorder}" VerticalOptions="Start" />
                <Button Grid.Column="0" Text="File" Clicked="OnSendTestFileClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShellMuted}"
                        FontSize="10" Padding="10,6" CornerRadius="3" />
                <Entry Grid.Column="1" x:Name="MessageEntry" Placeholder="Message..."
                       BackgroundColor="{StaticResource CoalInput}"
                       TextColor="{StaticResource SeaShell}"
                       PlaceholderColor="{StaticResource SeaShellMuted}"
                       FontSize="{OnIdiom Phone=12, Default=13}" />
                <Button Grid.Column="2" Text="X" Clicked="OnClearChatClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShellMuted}"
                        FontSize="10" Padding="8,6" CornerRadius="3" />
                <Button Grid.Column="3" Text="Send" Clicked="OnSendClicked"
                        BackgroundColor="{StaticResource AccentBlue}"
                        TextColor="{StaticResource SeaShell}"
                        FontSize="{OnIdiom Phone=11, Default=12}"
                        Padding="14,6" CornerRadius="3" />
            </Grid>

            <!-- File transfer status row -->
            <Grid Grid.Row="4" Padding="10,4,8,4"
                  ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="4"
                  BackgroundColor="{StaticResource CoalPanel}">
                <Label Grid.Column="0" x:Name="FileTransferLabel" Text="File: idle"
                       FontSize="9" TextColor="{StaticResource SeaShellMuted}" VerticalOptions="Center" />
                <Button Grid.Column="1" Text="Resume" Clicked="OnResumeFileClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShellMuted}"
                        FontSize="9" Padding="6,2" CornerRadius="3" />
                <Label Grid.Column="2" x:Name="LogCountLabel" Text=""
                       FontSize="9" TextColor="{StaticResource SeaShellMuted}" VerticalOptions="Center" />
                <Button Grid.Column="3" Text="Copy" Clicked="OnCopyLogsClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShellMuted}"
                        FontSize="9" Padding="6,2" CornerRadius="3" />
                <Button Grid.Column="4" x:Name="ClearLogsBtn" Text="Clear" Clicked="OnClearLogsClicked"
                        BackgroundColor="{StaticResource CoalSurface}"
                        TextColor="{StaticResource SeaShellMuted}"
                        FontSize="9" Padding="6,2" CornerRadius="3" />
            </Grid>

            <!-- Technical logs -->
            <Grid Grid.Row="5" RowDefinitions="Auto,*" BackgroundColor="{StaticResource CoalPanel}">
                <BoxView Grid.Row="0" HeightRequest="1" Color="{StaticResource CoalBorder}" />
                <ScrollView Grid.Row="1" x:Name="TechLogScrollView" Padding="10,6">
                    <VerticalStackLayout x:Name="TechLogStack" Spacing="1" />
                </ScrollView>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
